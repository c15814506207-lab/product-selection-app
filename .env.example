# Supabase（必填；Netlify 须在 Environment variables 里配置，否则线上包里没有 URL/key 会白屏/黑屏）
# VITE_SUPABASE_URL 若省略，前端会 fallback 到代码内默认项目地址，仍建议显式填写你的 Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key

# 可选：单独指定某个 Edge Function 的完整 URL（不设则自动为 VITE_SUPABASE_URL + /functions/v1/<名称>）
# VITE_EDGE_ANALYZE_URL=
# VITE_EDGE_SANDBOX_URL=
# VITE_EDGE_OPTIMIZE_URL=

# 可选：识图填表（未部署对应 Function 时，按钮会请求失败并在错误区提示）
# VITE_EDGE_FILL_FROM_IMAGE_URL=

# 积分：原子扣费/加积分（与 Supabase RPC debit_points_atomic / credit_points_atomic 配套）
# 不设则自动为 VITE_SUPABASE_URL + /functions/v1/<名称>
# VITE_EDGE_WALLET_DEBIT_URL=
# VITE_EDGE_WALLET_REFUND_URL=
# VITE_EDGE_CREATE_ALIPAY_PAGE_PAY_URL=   # 不设则同项目 /functions/v1/create-alipay-page-pay

# Edge Secrets（仅在 Supabase 控制台/CLI 配置，勿写进 VITE_）
# WALLET_CREDIT_SECRET — wallet-refund 加积分必带请求头 x-internal-credit-secret；勿泄露、勿打包进前端
#
# 支付宝「电脑网站支付」+ 异步通知（部署 create-alipay-page-pay + alipay-notify 后，Secrets 配在 Supabase）：
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=（应用私钥，PKCS8，一行或多行 PEM）
# ALIPAY_ALIPAY_PUBLIC_KEY=（支付宝公钥，非应用公钥）
# ALIPAY_RETURN_URL=https://你的站点/billing?paid=1&return=alipay（同步跳转，仅展示提示；入账以异步通知为准）
# ALIPAY_NOTIFY_URL=https://<project-ref>.supabase.co/functions/v1/alipay-notify
# ALIPAY_AMOUNT_P100 / ALIPAY_AMOUNT_P500 / ALIPAY_AMOUNT_P1000 — 各档位标价（元，如 0.01），须与开放平台商品一致
# 可选：ALIPAY_GATEWAY=https://openapi.alipaydev.com/gateway.do（沙箱）

# 开发环境默认无限积分；若要本地测真实扣费，设为 false
# VITE_DEV_UNLIMITED_POINTS=false

# —— Supabase Edge Secrets（识图函数默认 Polo：xy.poloapi.com，只需 GEMINI_API_KEY=SK）
# 换站点：GEMINI_API_BASE_URL 或 POLOAPI_BASE_URL
# 改走官方 Google：GEMINI_OFFICIAL_GOOGLE=true + 官方 GEMINI_API_KEY
# 可选：GEMINI_VISION_MODEL（与模型广场名称一致）
